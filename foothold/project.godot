; Godot 4 project — Foothold (working title)
; Territory-control team shooter. Milestone 0->1 vertical slice.
; GL Compatibility renderer + 2D keeps it light on low-end laptops.

config_version=5

[application]
config/name="Foothold (working title)"
config/description="Territory-control team shooter — Milestone 0->1 slice. See README.md."
run/main_scene="res://main/main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]
EventBus="*res://shared/event_bus.gd"
Defs="*res://shared/defs.gd"
Net="*res://shared/net.gd"

[display]
window/size/viewport_width=760
window/size/viewport_height=800
window/stretch/mode="canvas_items"

[rendering]
renderer/rendering_method="gl_compatibility"
